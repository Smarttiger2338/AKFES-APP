# Copy this file to .env for local development. Never commit real secrets.
AKFES_ENVIRONMENT=development
AKFES_HOST=127.0.0.1
AKFES_PORT=8000
AKFES_DOCS_ENABLED=true
AKFES_CORS_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,http://tauri.localhost,tauri://localhost
AKFES_ALLOWED_HOSTS=127.0.0.1,localhost
AKFES_MAX_UPLOAD_BYTES=104857600
