# Copy this file to .env for local development. Never commit real secrets.
AKFES_ENVIRONMENT=development
AKFES_HOST=127.0.0.1
AKFES_PORT=8000
AKFES_DOCS_ENABLED=true
AKFES_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:1420,http://127.0.0.1:1420,http://tauri.localhost,tauri://localhost
AKFES_ALLOWED_HOSTS=127.0.0.1,localhost
AKFES_MAX_UPLOAD_BYTES=104857600
AKFES_DATABASE_PATH=data/akfes.sqlite3
AKFES_SESSION_TTL_SECONDS=900
AKFES_CHALLENGE_TTL_SECONDS=60
AKFES_DEVICE_BINDING_REQUIRED=true
AKFES_PBKDF2_ITERATIONS=200000

# Generate independent random values of at least 32 characters.
# Never reuse either value and never place production values in the client.
AKFES_LICENSE_HMAC_SECRET=replace-with-a-random-license-hmac-secret
AKFES_ADMIN_TOKEN=replace-with-a-random-administrator-token
