{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AKFES",
  "version": "2.0.0",
  "identifier": "io.github.smarttiger2338.akfes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AKFES",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://* http://127.0.0.1:*; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
