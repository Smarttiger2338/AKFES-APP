{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AKFES",
  "version": "2.0.0",
  "identifier": "io.github.smarttiger2338.akfes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AKFES",
        "width": 1100,
        "height": 720,
        "minWidth": 640,
        "minHeight": 460,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://* http://127.0.0.1:* http://localhost:*; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "resources": {
      "binaries/akfes-server.exe": "akfes-server.exe"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY1NzZCN0Y3Mjg3MTM3N0YKUldSL04zRW85N2QyWld5Q21OK2ZGUFB6OFp0ZTR1b00ydS9ueFovWFRWRXF6a0FLcUN2QjlZU20K",
      "endpoints": [
        "https://github.com/Smarttiger2338/AKFES-APP/releases/latest/download/latest-desktop.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
